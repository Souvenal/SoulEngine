{
  "permissions": {
    "allow": [
      "Bash(./Engine/Binaries/*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/clang-format.sh"
          }
        ]
      }
    ]
  }
}
